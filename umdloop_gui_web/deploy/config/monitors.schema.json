{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MonitorConfig",
  "description": "Monitor configuration for a UMD Loop CC computer. Maps X display indexes to monitor slots.",
  "type": "object",
  "required": ["host_id", "displays"],
  "additionalProperties": false,
  "properties": {
    "host_id": {
      "type": "string",
      "enum": ["cc1", "cc2"],
      "description": "Identifier for the CC computer (cc1 = left, cc2 = right)."
    },
    "displays": {
      "type": "array",
      "description": "List of display-to-slot mappings.",
      "items": {
        "type": "object",
        "required": ["x_display_index", "monitor_slot"],
        "additionalProperties": false,
        "properties": {
          "x_display_index": {
            "type": "integer",
            "minimum": 0,
            "description": "X11 display index for this monitor."
          },
          "monitor_slot": {
            "type": "string",
            "enum": ["slot-1", "slot-2", "slot-3", "slot-4", "slot-5"],
            "description": "Logical monitor slot identifier."
          }
        }
      }
    }
  }
}
